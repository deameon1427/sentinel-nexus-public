---
import AcademyLayout from '../../layouts/AcademyLayout.astro';
---

<AcademyLayout
  title="Verify Certificate | Sentinel Nexus Academy"
  description="Verify an AI Security Fundamentals certificate issued by Sentinel Nexus Academy."
  noindex={true}
>
  <div class="verify-page">
    <div class="academy-container">

      <!-- Loading state -->
      <div id="verify-loading" class="verify-state">
        <div class="verify-spinner"></div>
        <p>Verifying certificate...</p>
      </div>

      <!-- Invalid state -->
      <div id="verify-invalid" class="verify-state" style="display:none">
        <div class="verify-icon verify-icon-invalid">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <line x1="15" y1="9" x2="9" y2="15"/>
            <line x1="9" y1="9" x2="15" y2="15"/>
          </svg>
        </div>
        <h2>Certificate Not Found</h2>
        <p>This certificate token is invalid or has expired. If you believe this is an error, contact <a href="mailto:contact@sentinel-nexus.com">contact@sentinel-nexus.com</a>.</p>
      </div>

      <!-- No token state -->
      <div id="verify-no-token" class="verify-state" style="display:none">
        <div class="verify-icon verify-icon-warn">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
            <line x1="12" y1="9" x2="12" y2="13"/>
            <line x1="12" y1="17" x2="12.01" y2="17"/>
          </svg>
        </div>
        <h2>No Certificate Token</h2>
        <p>This page requires a verification token. Use the link provided in your certificate email, or visit <a href="/">academy.sentinel-nexus.com</a> to enroll.</p>
      </div>

      <!-- Valid certificate display -->
      <div id="verify-valid" style="display:none">
        <div class="cert-valid-badge">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          Verified Certificate
        </div>

        <div class="certificate">
          <div class="cert-header">
            <img src="/images/icon-with-initals.webp" alt="Sentinel Nexus" class="cert-logo-img" />
            <div class="cert-header-text">
              <span class="cert-issuer-label">Sentinel Nexus Academy</span>
              <span class="cert-type-label">Certificate of Completion</span>
            </div>
          </div>

          <div class="cert-body">
            <p class="cert-awarded-to">This certifies that</p>
            <p class="cert-name" id="cert-name">...</p>
            <p class="cert-awarded-text">has successfully completed</p>
            <p class="cert-course-title">AI Security Fundamentals</p>
            <p class="cert-course-sub">Sentinel Nexus Academy &bull; Practitioner Certification</p>
          </div>

          <div class="cert-footer">
            <div class="cert-detail">
              <span class="cert-detail-label">Issue Date</span>
              <span class="cert-detail-value" id="cert-issue-date">...</span>
            </div>
            <div class="cert-detail">
              <span class="cert-detail-label">Organization</span>
              <span class="cert-detail-value" id="cert-company">...</span>
            </div>
            <div class="cert-detail">
              <span class="cert-detail-label">Certificate ID</span>
              <span class="cert-detail-value cert-id-value" id="cert-token">...</span>
            </div>
          </div>
        </div>

        <div class="verify-actions">
          <p class="verify-note">This certificate was issued by Sentinel Nexus Academy and can be verified at this URL.</p>
          <a
            id="linkedin-share-btn"
            href="https://www.linkedin.com/shareArticle?mini=true&url=https%3A%2F%2Facademy.sentinel-nexus.com&title=AI%20Security%20Fundamentals%20Certificate%20-%20Sentinel%20Nexus%20Academy"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-secondary linkedin-share"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>
            </svg>
            Share on LinkedIn
          </a>
        </div>
      </div>

    </div>
  </div>
</AcademyLayout>

<script>
  async function verifyToken() {
    const params = new URLSearchParams(window.location.search);
    const token = params.get('token');

    const loadingEl = document.getElementById('verify-loading');
    const invalidEl = document.getElementById('verify-invalid');
    const noTokenEl = document.getElementById('verify-no-token');
    const validEl = document.getElementById('verify-valid');

    function showOnly(el: HTMLElement | null) {
      [loadingEl, invalidEl, noTokenEl, validEl].forEach(e => {
        if (e) e.style.display = 'none';
      });
      if (el) el.style.display = 'block';
    }

    if (!token) {
      showOnly(noTokenEl);
      return;
    }

    try {
      const res = await fetch(
        `https://n8n.sentinel-nexus.com/webhook/academy-verify?token=${encodeURIComponent(token)}`
      );
      const data = await res.json() as {
        valid: boolean;
        name?: string;
        certTitle?: string;
        issueDate?: string;
        company?: string;
      };

      if (!data.valid) {
        showOnly(invalidEl);
        return;
      }

      // Populate certificate
      const nameEl = document.getElementById('cert-name');
      const dateEl = document.getElementById('cert-issue-date');
      const companyEl = document.getElementById('cert-company');
      const tokenEl = document.getElementById('cert-token');

      if (nameEl) nameEl.textContent = data.name ?? '';
      if (dateEl) dateEl.textContent = data.issueDate
        ? new Date(data.issueDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
        : '';
      if (companyEl) companyEl.textContent = data.company ?? 'N/A';
      if (tokenEl) tokenEl.textContent = token.slice(0, 8).toUpperCase() + '...';

      // Update LinkedIn share URL with name
      const linkedinBtn = document.getElementById('linkedin-share-btn');
      if (linkedinBtn && data.name) {
        const shareUrl = `https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(window.location.href)}&title=${encodeURIComponent(`${data.name} earned the AI Security Fundamentals Certificate from Sentinel Nexus Academy`)}`;
        (linkedinBtn as HTMLAnchorElement).href = shareUrl;
      }

      showOnly(validEl);

      try {
        (window as any).umami?.track('cert-verify', { valid: true });
      } catch(_) {}

    } catch(_) {
      showOnly(invalidEl);
    }
  }

  verifyToken();
</script>

<style>
  .verify-page {
    padding: 4rem 0 6rem;
    min-height: 70vh;
  }

  .verify-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
    padding: 3rem 1.5rem;
    max-width: 480px;
    margin: 0 auto;
  }

  .verify-state h2 {
    font-size: 1.5rem;
    font-weight: 700;
  }

  .verify-state p {
    color: var(--color-text-muted);
    line-height: 1.6;
    font-size: 0.95rem;
  }

  .verify-state p a {
    color: var(--color-accent-1);
    text-decoration: underline;
  }

  .verify-spinner {
    width: 40px;
    height: 40px;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .verify-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .verify-icon-invalid {
    background: rgba(207, 21, 21, 0.1);
    color: var(--color-primary);
    border: 2px solid rgba(207, 21, 21, 0.25);
  }

  .verify-icon-warn {
    background: rgba(251, 191, 36, 0.1);
    color: #f59e0b;
    border: 2px solid rgba(251, 191, 36, 0.25);
  }

  /* Valid state */
  #verify-valid {
    max-width: 680px;
    margin: 0 auto;
  }

  .cert-valid-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(16, 185, 129, 0.1);
    color: var(--color-accent-2);
    border: 1px solid rgba(16, 185, 129, 0.25);
    border-radius: 999px;
    padding: 0.4rem 1rem;
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 2rem;
  }

  /* Certificate */
  .certificate {
    background: var(--color-bg-card);
    border: 2px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 2rem;
  }

  .cert-header {
    background: var(--color-bg-secondary);
    border-bottom: 1px solid var(--color-border);
    padding: 1.5rem 2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .cert-logo-img {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    object-fit: contain;
  }

  .cert-header-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .cert-issuer-label {
    font-weight: 700;
    font-size: 0.95rem;
  }

  .cert-type-label {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .cert-body {
    padding: 3rem 2rem;
    text-align: center;
    border-bottom: 1px solid var(--color-border);
  }

  .cert-awarded-to,
  .cert-awarded-text {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .cert-name {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    color: var(--color-text);
  }

  .cert-course-title {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.4rem;
  }

  .cert-course-sub {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .cert-footer {
    padding: 1.5rem 2rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .cert-detail {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .cert-detail-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }

  .cert-detail-value {
    font-size: 0.9rem;
    font-weight: 500;
  }

  .cert-id-value {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .verify-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .verify-note {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-align: center;
  }

  .linkedin-share {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    padding: 0.6rem 1.25rem;
  }

  @media (max-width: 540px) {
    .cert-footer {
      grid-template-columns: 1fr;
    }

    .cert-name {
      font-size: 1.5rem;
    }

    .cert-body {
      padding: 2rem 1.25rem;
    }
  }
</style>
