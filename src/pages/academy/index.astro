---
import AcademyLayout from '../../layouts/AcademyLayout.astro';
import AcademyEnrollForm from '../../components/AcademyEnrollForm.astro';
import { getCollection } from 'astro:content';

const modules = (await getCollection('academy', ({ data }) => !data.draft && !data.isFinal))
  .sort((a, b) => a.data.moduleNumber - b.data.moduleNumber);

const totalModules = modules.length;
---

<AcademyLayout
  title="AI Security Fundamentals Certificate | Sentinel Nexus Academy"
  description="Free certification for security practitioners, AI engineers, and governance leads. Build verified expertise in AI security, prompt injection, and compliance frameworks."
>
  <section class="hero">
    <div class="academy-container">
      <div class="hero-badge">Free Certification Program</div>
      <h1 class="hero-headline">AI Security Fundamentals</h1>
      <p class="hero-sub">
        A practitioner-grade certification covering the full AI attack surface, adversarial techniques,
        governance frameworks, and how to build a defensible AI security program.
        Designed for security professionals, AI engineers, and governance leads.
      </p>
      <div class="hero-meta">
        <div class="meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          {totalModules} modules + final assessment
        </div>
        <div class="meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          ~2.5 hours total
        </div>
        <div class="meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.3a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.45h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.29 6.29l.73-.73a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 17.73"/></svg>
          Certificate emailed on completion
        </div>
        <div class="meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="20 6 9 17 4 12"/></svg>
          Business email required
        </div>
      </div>
    </div>
  </section>

  <section class="main-content">
    <div class="academy-container content-grid">
      <div class="content-left">

        <!-- What you'll learn -->
        <div class="section-card">
          <h2 class="section-title">What You'll Learn</h2>
          <div class="learn-grid">
            <div class="learn-item">
              <div class="learn-icon security">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div>
                <strong>The AI Attack Surface</strong>
                <p>Model security, supply chain risks, agentic AI threats, and infrastructure exposure.</p>
              </div>
            </div>
            <div class="learn-item">
              <div class="learn-icon security">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><circle cx="12" cy="12" r="10"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              </div>
              <div>
                <strong>Prompt Injection & Adversarial Techniques</strong>
                <p>Direct and indirect prompt injection, jailbreaking, data poisoning, and model inversion.</p>
              </div>
            </div>
            <div class="learn-item">
              <div class="learn-icon governance">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              </div>
              <div>
                <strong>AI Governance & Compliance</strong>
                <p>EU AI Act, NIST AI RMF, ISO 42001, and building a compliant AI program.</p>
              </div>
            </div>
            <div class="learn-item">
              <div class="learn-icon implementation">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              </div>
              <div>
                <strong>Building an AI Security Program</strong>
                <p>Risk frameworks, red teaming AI systems, incident response, and vendor assessment.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Curriculum -->
        <div class="section-card">
          <h2 class="section-title">Curriculum</h2>
          <div class="module-list">
            {modules.map((mod) => (
              <div class="module-item">
                <div class="module-num">{String(mod.data.moduleNumber).padStart(2, '0')}</div>
                <div class="module-info">
                  <span class="module-title">{mod.data.title}</span>
                  <span class="module-duration">{mod.data.duration}</span>
                </div>
              </div>
            ))}
            <div class="module-item module-final">
              <div class="module-num">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
              </div>
              <div class="module-info">
                <span class="module-title">Final Assessment</span>
                <span class="module-duration">30 min &bull; 80% to pass</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Instructor -->
        <div class="section-card instructor-card">
          <h2 class="section-title">Your Instructor</h2>
          <div class="instructor">
            <div class="instructor-avatar">CD</div>
            <div class="instructor-bio">
              <strong>Casey Davis</strong>
              <p>
                25 years of security mentoring, red teaming, and enterprise AI implementation.
                We've secured AI systems across fintech, healthcare, and critical infrastructure.
                This program distills practitioner knowledge you won't find in vendor certifications.
              </p>
            </div>
          </div>
        </div>

        <!-- Who it's for -->
        <div class="section-card">
          <h2 class="section-title">Who It's For</h2>
          <ul class="audience-list">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              Security professionals adding AI to their practice
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              AI/ML engineers who need security depth
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              Governance and compliance leads overseeing AI systems
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              Risk managers evaluating AI vendor products
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              IT leaders building AI security policy
            </li>
          </ul>
        </div>

      </div>

      <div class="content-right">
        <div class="enroll-sticky">
          <AcademyEnrollForm />
          <div class="cert-preview">
            <div class="cert-preview-inner">
              <div class="cert-logo">SN</div>
              <p class="cert-label">Certificate of Completion</p>
              <p class="cert-title">AI Security Fundamentals</p>
              <p class="cert-issuer">Sentinel Nexus Academy</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</AcademyLayout>

<style>
  .hero {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--color-border);
    text-align: center;
    background: radial-gradient(ellipse at top, rgba(207, 21, 21, 0.06) 0%, transparent 60%);
  }

  .hero-badge {
    display: inline-block;
    background: rgba(207, 21, 21, 0.12);
    color: var(--color-primary);
    border: 1px solid rgba(207, 21, 21, 0.25);
    border-radius: 999px;
    padding: 0.35rem 1rem;
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1.25rem;
  }

  .hero-headline {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 1.25rem;
  }

  .hero-sub {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 640px;
    margin: 0 auto 2rem;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.25rem 2rem;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .meta-item svg {
    color: var(--color-accent-2);
    flex-shrink: 0;
  }

  /* Main layout */
  .main-content {
    padding: 3rem 0 5rem;
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 3rem;
    align-items: start;
  }

  .content-left {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .section-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.75rem;
  }

  .section-title {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
  }

  /* Learn grid */
  .learn-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .learn-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .learn-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .learn-icon.security { background: rgba(207, 21, 21, 0.1); color: var(--color-primary); }
  .learn-icon.governance { background: rgba(139, 92, 246, 0.1); color: var(--color-accent-3); }
  .learn-icon.implementation { background: rgba(59, 130, 246, 0.1); color: var(--color-accent-1); }

  .learn-item strong {
    display: block;
    font-size: 0.9rem;
    margin-bottom: 0.2rem;
  }

  .learn-item p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
  }

  /* Module list */
  .module-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .module-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .module-item:last-child { border-bottom: none; }

  .module-num {
    width: 32px;
    height: 32px;
    background: var(--color-bg-secondary);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .module-final .module-num {
    background: rgba(207, 21, 21, 0.1);
    color: var(--color-primary);
  }

  .module-info {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex: 1;
    gap: 1rem;
  }

  .module-title {
    font-size: 0.9rem;
    font-weight: 500;
  }

  .module-duration {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  /* Instructor */
  .instructor {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .instructor-avatar {
    width: 48px;
    height: 48px;
    background: var(--color-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.875rem;
    color: white;
    flex-shrink: 0;
  }

  .instructor-bio strong {
    display: block;
    margin-bottom: 0.4rem;
  }

  .instructor-bio p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* Audience list */
  .audience-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .audience-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
  }

  .audience-list svg {
    color: var(--color-accent-2);
    flex-shrink: 0;
  }

  /* Right column */
  .enroll-sticky {
    position: sticky;
    top: 5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* Certificate preview */
  .cert-preview {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    text-align: center;
  }

  .cert-preview-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.5rem;
    border: 2px dashed var(--color-border);
    border-radius: 8px;
  }

  .cert-logo {
    width: 48px;
    height: 48px;
    background: var(--color-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 1rem;
    color: white;
    margin-bottom: 0.5rem;
  }

  .cert-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
  }

  .cert-title {
    font-size: 1rem;
    font-weight: 700;
  }

  .cert-issuer {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .content-grid {
      grid-template-columns: 1fr;
    }

    .enroll-sticky {
      position: static;
    }

    .content-right {
      order: -1;
    }

    .hero-meta {
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
    }
  }
</style>
