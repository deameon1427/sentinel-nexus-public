---
interface Props {
  slug: string;
  previewLength: number;
}

const { slug, previewLength } = Astro.props;
---

<div class="gate-wrapper" data-preview-length={previewLength}>
  <div class="preview-container">
    <div class="preview-content" id="preview-content">
      <slot name="preview" />
    </div>
    <div class="fade-overlay" id="fade-overlay"></div>
  </div>

  <div class="gate-form-wrapper" id="gate-form-wrapper">
    <div class="gate-form-inner">
      <div class="gate-icon">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
        </svg>
      </div>
      <h3>Access the Full Paper</h3>
      <p>Enter your details to read the complete research paper, including all mathematical derivations and security implications.</p>
      <form id="whitepaper-gate-form" novalidate>
        <input type="hidden" name="source" value="whitepaper-gate" />
        <input type="hidden" name="slug" value={slug} />
        <div class="form-row">
          <div class="form-group">
            <label for="gate-name">Name</label>
            <input type="text" id="gate-name" name="name" placeholder="Your name" required />
          </div>
          <div class="form-group">
            <label for="gate-email">Work Email</label>
            <input type="email" id="gate-email" name="email" placeholder="you@company.com" required />
          </div>
        </div>
        <button type="submit" class="btn btn-primary gate-submit">
          <span class="btn-text">Read Full Paper</span>
          <span class="btn-loading" style="display:none">Unlocking...</span>
        </button>
        <p class="gate-privacy">No spam. Unsubscribe anytime.</p>
      </form>
      <div class="gate-success" id="gate-success" style="display:none">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
          <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
        <p>Unlocked. Scroll down to read.</p>
      </div>
    </div>
  </div>

  <div class="full-content" id="full-content" style="display:none">
    <slot name="full" />
  </div>
</div>

<script>
  const form = document.getElementById('whitepaper-gate-form') as HTMLFormElement | null;
  const fullContent = document.getElementById('full-content');
  const gateWrapper = document.getElementById('gate-form-wrapper');
  const fadeOverlay = document.getElementById('fade-overlay');
  const gateSuccess = document.getElementById('gate-success');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btnText = form.querySelector('.btn-text') as HTMLElement | null;
      const btnLoading = form.querySelector('.btn-loading') as HTMLElement | null;
      const submitBtn = form.querySelector('.gate-submit') as HTMLButtonElement | null;

      if (btnText) btnText.style.display = 'none';
      if (btnLoading) btnLoading.style.display = 'inline';
      if (submitBtn) submitBtn.disabled = true;

      const data: Record<string, string> = {};
      new FormData(form).forEach((value, key) => {
        data[key] = value.toString();
      });

      try {
        await fetch('https://n8n.sentinel-nexus.com/webhook/contact-form', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
      } catch (_) {
        // Reveal content even if submission fails - don't block access
      }

      // Reveal full content
      if (fullContent) fullContent.style.display = 'block';
      if (fadeOverlay) fadeOverlay.style.display = 'none';
      if (gateWrapper) gateWrapper.style.display = 'none';

      // Fire Umami conversion event
      if (typeof (window as any).umami !== 'undefined') {
        (window as any).umami.track('whitepaper-unlocked', { slug: data.slug });
      }

      // Show success state inline if form wrapper still visible
      if (gateSuccess) gateSuccess.style.display = 'flex';
    });
  }
</script>

<style>
  .gate-wrapper {
    margin-top: 3rem;
  }

  .preview-container {
    position: relative;
  }

  .fade-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 200px;
    background: linear-gradient(to bottom, transparent, var(--color-bg));
    pointer-events: none;
  }

  .gate-form-wrapper {
    margin: 2rem 0;
  }

  .gate-form-inner {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-primary);
    border-radius: 12px;
    padding: 2.5rem;
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  .gate-icon {
    width: 56px;
    height: 56px;
    background: color-mix(in srgb, var(--color-primary) 15%, transparent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.25rem;
    color: var(--color-primary);
  }

  .gate-form-inner h3 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .gate-form-inner > p {
    color: var(--color-text-muted);
    margin-bottom: 1.75rem;
    line-height: 1.6;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1rem;
    text-align: left;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
  }

  .form-group input {
    padding: 0.65rem 0.85rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    color: var(--color-text);
    font-size: 0.95rem;
    transition: border-color 0.2s ease;
  }

  .form-group input:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  .gate-submit {
    width: 100%;
    padding: 0.85rem;
    font-size: 1rem;
    margin-top: 0.5rem;
  }

  .gate-privacy {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-top: 0.75rem;
    margin-bottom: 0;
  }

  .gate-success {
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    color: var(--color-accent-2);
    font-weight: 500;
    padding-top: 0.5rem;
  }

  .gate-success p {
    margin: 0;
  }

  @media (max-width: 600px) {
    .form-row {
      grid-template-columns: 1fr;
    }

    .gate-form-inner {
      padding: 1.75rem 1.25rem;
    }
  }
</style>
